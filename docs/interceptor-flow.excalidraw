      "points": [[0,0],[0,35]],
      "strokeColor": "#1e1e1e", "strokeWidth": 2
    },

    {
      "id": "l1",
      "type": "rectangle",
      "x": 270, "y": 450, "width": 300, "height": 130,
      "angle": 0, "strokeColor": "#f08c00", "backgroundColor": "#ffec99",
      "fillStyle": "solid", "strokeWidth": 2, "roughness": 1, "opacity": 100,
      "roundness": { "type": 3 }
    },
    {
      "id": "l1-label",
      "type": "text",
      "x": 280, "y": 458, "width": 280, "height": 115,
      "text": "4. L1 CHECK\nengine.CheckL1()\n\n• Refill token bucket\n• windowCount+1 > burst?\n  → BLOCK burst_detected 0.95\n• tokens < 1.0?\n  → BLOCK rate_limited 0.90\n• else → ALLOW",
      "fontSize": 13, "fontFamily": 1, "textAlign": "left",
      "strokeColor": "#f08c00"
    },

    {
      "id": "l1-block",
      "type": "rectangle",
      "x": 650, "y": 470, "width": 180, "height": 50,
      "angle": 0, "strokeColor": "#e03131", "backgroundColor": "#ffc9c9",
      "fillStyle": "solid", "strokeWidth": 2, "roughness": 1, "opacity": 100,
      "roundness": { "type": 3 }
    },
    {
      "id": "l1-block-label",
      "type": "text",
      "x": 660, "y": 483, "width": 160, "height": 25,
      "text": "BLOCK (conf 0.90–0.95)",
      "fontSize": 13, "fontFamily": 1, "textAlign": "center",
      "strokeColor": "#e03131"
    },
    {
      "id": "arr-l1-block",
      "type": "arrow",
      "x": 570, "y": 495, "width": 80, "height": 0,
      "points": [[0,0],[80,0]],
      "strokeColor": "#e03131", "strokeWidth": 2
    },

    {
      "id": "arr3",
      "type": "arrow",
      "x": 420, "y": 580, "width": 0, "height": 35,
      "points": [[0,0],[0,35]],
      "strokeColor": "#1e1e1e", "strokeWidth": 2
    },

    {
      "id": "l2",
      "type": "rectangle",
      "x": 270, "y": 615, "width": 300, "height": 110,
      "angle": 0, "strokeColor": "#6741d9", "backgroundColor": "#e5dbff",
      "fillStyle": "solid", "strokeWidth": 2, "roughness": 1, "opacity": 100,
      "roundness": { "type": 3 }
    },
    {
      "id": "l2-label",
      "type": "text",
      "x": 280, "y": 623, "width": 280, "height": 95,
      "text": "5. L2 SEQUENCE CHECK\nengine.CheckL2()\n\n• /home  → seenHome = true\n• /register + !seenHome\n  → SUSPICIOUS\n    sequence_violation 0.70\n• else → clean",
      "fontSize": 13, "fontFamily": 1, "textAlign": "left",
      "strokeColor": "#6741d9"
    },

    {
      "id": "l2-susp",
      "type": "rectangle",
      "x": 650, "y": 635, "width": 180, "height": 50,
      "angle": 0, "strokeColor": "#6741d9", "backgroundColor": "#e5dbff",
      "fillStyle": "solid", "strokeWidth": 2, "roughness": 1, "opacity": 100,
      "roundness": { "type": 3 }
    },
    {
      "id": "l2-susp-label",
      "type": "text",
      "x": 660, "y": 648, "width": 160, "height": 25,
      "text": "SUSPICIOUS (conf 0.70)",
      "fontSize": 13, "fontFamily": 1, "textAlign": "center",
      "strokeColor": "#6741d9"
    },
    {
      "id": "arr-l2-susp",
      "type": "arrow",
      "x": 570, "y": 660, "width": 80, "height": 0,
      "points": [[0,0],[80,0]],
      "strokeColor": "#6741d9", "strokeWidth": 2
    },

