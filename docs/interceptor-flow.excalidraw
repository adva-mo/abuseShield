      "type": "text",
      "x": 310, "y": 332, "width": 220, "height": 75,
      "text": "3. ENTITY ID\nFNV-1a64(\n  ip/24 + User-Agent\n  + TLS placeholder\n) → hex",
      "fontSize": 13, "fontFamily": 1, "textAlign": "center",
      "strokeColor": "#1e1e1e"
