      "fillStyle": "solid", "strokeWidth": 2, "roughness": 1, "opacity": 100,
      "roundness": { "type": 3 }
    },
    {
      "id": "blocked-calc-label",
      "type": "text",
      "x": 280, "y": 893, "width": 280, "height": 85,
      "text": "7. COMPUTE blocked\n\nshouldBlock =\n  decision==BLOCK\n  OR (decision==SUSPICIOUS\n      && blockOnSuspicious)\nblocked = !shadowMode && shouldBlock",
      "fontSize": 13, "fontFamily": 1, "textAlign": "left",
      "strokeColor": "#1e1e1e"
    },

