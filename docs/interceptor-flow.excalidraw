    },
    {
      "id": "emit-label",
      "type": "text",
      "x": 280, "y": 1028, "width": 280, "height": 95,
      "text": "8. EMIT SecurityEvent (async)\n\n{ timestamp, entity_id,\n  ip, user_agent, path,\n  decision, reason,\n  confidence, signals[],\n  shadow_mode, blocked }\n→ buffered channel → JSON stdout",
