      "fillStyle": "solid", "strokeWidth": 2, "roughness": 1, "opacity": 100,
      "roundness": { "type": 3 }
    },
    {
      "id": "merge-label",
      "type": "text",
      "x": 280, "y": 768, "width": 280, "height": 75,
      "text": "6. MERGE DECISIONS\n\nL1 BLOCK   → decision = BLOCK\nL2 SUSP    → decision = SUSPICIOUS\nelse       → decision = ALLOW\nsignals[]  = all fired rules",
      "fontSize": 13, "fontFamily": 1, "textAlign": "left",
      "strokeColor": "#1e1e1e"
    },

